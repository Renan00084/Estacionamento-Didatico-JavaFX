<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox alignment="CENTER" prefHeight="600.0" prefWidth="800.0" spacing="20.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.estacionamentojavafx.HelloController">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>
   <Label text="Estacionamento Didático">
      <VBox.margin>
         <Insets bottom="20.0" />
      </VBox.margin>
      <font>
         <Font name="Verdana Bold" size="34.0" />
      </font>
   </Label>
   <HBox prefHeight="300.0" prefWidth="760.0">
      <children>
         <VBox prefHeight="190.0" prefWidth="380.0" style="-fx-border-radius: 3; -fx-border-color: gray; -fx-border-width: 1;">
            <HBox.margin>
               <Insets right="20.0" />
            </HBox.margin>
            <children>
               <Label text="Registro de Entrada">
                  <VBox.margin>
                     <Insets left="110.0" />
                  </VBox.margin>
                  <font>
                     <Font name="System Bold" size="16.0" />
                  </font>
               </Label>
               <Label text="Digite a placa do carro:">
                  <VBox.margin>
                     <Insets top="10.0" />
                  </VBox.margin></Label>
               <TextField />
               <Label text="Digite o modelo do carro">
                  <VBox.margin>
                     <Insets top="10.0" />
                  </VBox.margin></Label>
               <TextField />
               <Label text="Digite a vaga na qual voce deseja estacioar">
                  <VBox.margin>
                     <Insets top="10.0" />
                  </VBox.margin></Label>
               <TextField />
               <Button mnemonicParsing="false" text="Registrar Entrada">
                  <VBox.margin>
                     <Insets left="115.0" top="10.0" />
                  </VBox.margin></Button>
            </children>
            <padding>
               <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
            </padding>
         </VBox>
         <VBox prefHeight="200.0" prefWidth="380.0" style="-fx-border-color: gray; -fx-border-radius: 3; -fx-border-width: 1;">
            <children>
               <Label text="Registro de Saída">
                  <font>
                     <Font name="System Bold" size="16.0" />
                  </font>
                  <VBox.margin>
                     <Insets left="110.0" />
                  </VBox.margin>
               </Label>
               <Label text="Digite a placa do carro:">
                  <VBox.margin>
                     <Insets top="10.0" />
                  </VBox.margin></Label>
               <TextField />
               <Button mnemonicParsing="false" text="Registrar Saída">
                  <VBox.margin>
                     <Insets left="120.0" top="10.0" />
                  </VBox.margin></Button>
            </children>
            <padding>
               <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
            </padding>
         </VBox>
      </children>
   </HBox>
   <TableView prefHeight="200.0" prefWidth="200.0">
     <columns>
       <TableColumn prefWidth="135.0" text="N. VAGA" />
       <TableColumn prefWidth="227.0" text="ESTADO" />
         <TableColumn prefWidth="397.0" text="PLACA" />
     </columns>
   </TableView>
</VBox>
